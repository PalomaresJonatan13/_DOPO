comment9.text=\ @Test\r\n\ \ \ \ public\ void\ shouldNotPushLidIfTowerVisibleAndHeightReachedIsGreaterThanTowersHeight()\ {\r\n\ \ \ \ \ \ \ \ tower.makeVisible();\r\n\ \ \ \ \ \ \ \ //\ A\ message\ will\ be\ shown\ after\ trying\ to\ push\ the\ lid\r\n\ \ \ \ \ \ \ \ tower.pushCup(2);\r\n\ \ \ \ \ \ \ \ tower.pushCup(4);\r\n\ \ \ \ \ \ \ \ tower.pushLid(5);\r\n\ \ \ \ \ \ \ \ \r\n\ \ \ \ \ \ \ \ assertTowerState(\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ String[][]\ {{"cup",\ "2"},\ {"cup",\ "4"}},\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ int[]\ {3,\ 10},\r\n\ \ \ \ \ \ \ \ \ \ \ \ false\r\n\ \ \ \ \ \ \ \ );\r\n}
