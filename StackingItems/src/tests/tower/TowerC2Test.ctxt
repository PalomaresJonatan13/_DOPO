comment17.text=\ @Test\r\n\ \ \ \ public\ void\ shouldNotCoverIfVisibleAndNewHeightIsGreaterThanTowersHeight()\ {\r\n\ \ \ \ \ \ \ \ tower.makeVisible();\r\n\ \ \ \ \ \ \ \ tower.pushLid(3);\r\n\ \ \ \ \ \ \ \ tower.pushLid(4);\r\n\ \ \ \ \ \ \ \ tower.pushCup(4);\r\n\ \ \ \ \ \ \ \ tower.pushCup(3);\r\n\ \ \ \ \ \ \ \ tower.cover();\r\n\r\n\ \ \ \ \ \ \ \ assertTowerState(\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ String[][]\ {{"lid",\ "3"},\ {"lid",\ "4"},\ {"cup",\ "4"},\ {"cup",\ "3"}},\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ int[]\ {1,\ 2,\ 9,\ 8},\r\n\ \ \ \ \ \ \ \ \ \ \ \ false\r\n\ \ \ \ \ \ \ \ );\r\n}
