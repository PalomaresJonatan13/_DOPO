comment5.text=\ @Test\r\n\ \ \ \ public\ void\ shouldNotSwapIfVisibleAndNewHeightIsGreaterThanTowersHeight()\ {\r\n\ \ \ \ \ \ \ \ tower.makeVisible();\r\n\ \ \ \ \ \ \ \ tower.pushLid(1);\r\n\ \ \ \ \ \ \ \ tower.pushCup(4);\r\n\ \ \ \ \ \ \ \ tower.pushCup(3);\r\n\ \ \ \ \ \ \ \ tower.swap(\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ String[]\ {"lid",\ "1"},\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ String[]\ {"cup",\ "3"}\r\n\ \ \ \ \ \ \ \ );\r\n\r\n\ \ \ \ \ \ \ \ assertTowerState(\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ String[][]\ {{"lid",\ "1"},\ {"cup",\ "4"},\ {"cup",\ "3"}},\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ int[]\ {1,\ 8,\ 7},\r\n\ \ \ \ \ \ \ \ \ \ \ \ false\r\n\ \ \ \ \ \ \ \ );\r\n}
