comment6.text=\ @Test\r\n\ \ \ \ public\ void\ shouldSwapDifferentItemsIfTheyAreInAVisibleTowerAndNewHeightIsLessThanOrEqualToTowersHeight()\ {\r\n\ \ \ \ \ \ \ \ tower.makeVisible();\r\n\ \ \ \ \ \ \ \ tower.pushLid(1);\r\n\ \ \ \ \ \ \ \ tower.pushCup(4);\r\n\ \ \ \ \ \ \ \ tower.pushCup(2);\r\n\ \ \ \ \ \ \ \ tower.swap(\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ String[]\ {"lid",\ "1"},\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ String[]\ {"cup",\ "2"}\r\n\ \ \ \ \ \ \ \ );\r\n\r\n\ \ \ \ \ \ \ \ assertTowerState(\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ String[][]\ {{"cup",\ "2"},\ {"cup",\ "4"},\ {"lid",\ "1"}},\r\n\ \ \ \ \ \ \ \ \ \ \ \ new\ int[]\ {3,\ 10,\ 5},\r\n\ \ \ \ \ \ \ \ \ \ \ \ true\r\n\ \ \ \ \ \ \ \ );\r\n}
